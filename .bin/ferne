#!/usr/bin/env bash

# mirrors format: "<platform> <username> <ssh_template>"
# example mirrors config (note that order matters here: the first one will be the primary origin):
#   forgejo     2ug     ssh://git@codeberg.org/2ug/{repo}.git
#   github      200ug   git@github.com:200ug/{repo}.git
#
# org mirrors can be defined similarly, but they should be put into a separate directory
# inside the ORGS_DIR (each org separately, within that dir. "mirrors" and "tokens.gpg")
#   
# tokens file format (raw, i.e. before encryption):
#   GITHUB_TOKEN <gh_token>
#   FORGEJO_TOKEN <fj_token>
#
# fine-grained PATs should contain the following permissions (separately for each account/org):
#   - administration (r + w)  -> repo creation, deletion, etc. 
#   - contents (r + w)        -> repo content edits (incl. commits, branches, downloads, etc.)
#
# rough equivalents in forgejo would be "write:repository" and "write:organization" 
# (notably org-scoped tokens don't exist, thus the same token has access to both org & personal)

set -euo pipefail

PLACEHOLDER_DESCRIPTION="Repository created via the ferne mirroring system"
MIRRORS_CFG="$HOME/.config/ferne/mirrors"
ORGS_DIR="$HOME/.config/ferne/orgs"
# for each tokens file (personal & orgs): 
# gpg --encrypt --recipient 1530F5132A1228578D2B4168995EFD5C1B532B3E org_tokens && shred -u org_tokens
TOKENS_ENV="$HOME/.config/ferne/tokens.gpg"

GITHUB_API_BASE="https://api.github.com"
FORGEJO_API_BASE="https://codeberg.org/api/v1"
# TODO: add cgit (etc.) support later (for personal repos)

die() { echo "[!] error: $*" >&2; exit 1; }

require_cmd() {
    command -v "$1" &>/dev/null || die "'$1' required but not found in PATH"
}

prompt_description() {
    read -rp "[?] repository description: " repo_description
    [[ -z "$repo_description" ]] && repo_description="$PLACEHOLDER_DESCRIPTION"
}

export_tokens() {
    if [[ ! -f "$TOKENS_ENV" ]]; then
        die "no tokens file found at $TOKENS_ENV"
    fi

    # gpg-agent caches auth, so we only need to manually auth once over a single session
    _decrypted=$(gpg --quiet --decrypt "$TOKENS_ENV" 2>/dev/null) || die "failed to decrypt $TOKENS_ENV"

    while IFS= read -r _line; do
        [[ -z "$_line" || "$_line" =~ ^[[:space:]]*# ]] && continue
        parts=(${_line// / })
        # prevent accidental overwrites
        if [[ -z "${!parts[0]:-}" ]]; then
            # echo "key: '${parts[0]}', value: '${parts[1]}'"
            export "${parts[0]}=${parts[1]}"
        else
            die "environment variable '${parts[0]}' has already been set, aborting instead of overwriting"
        fi
    done <<< "$_decrypted"

    unset _decrypted
}

parse_mirrors() {
    [[ -f "$MIRRORS_CFG" ]] || die "no mirrors config found at $MIRRORS_CFG"

    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

        read -r platform username ssh_template <<< "$line"
        [[ -z "$platform" || -z "$username" || -z "$ssh_template" ]] && die "invalid mirror line: $line"

        mirror_platforms+=("$platform")
        mirror_users+=("$username")
        mirror_templates+=("$ssh_template")
        mirror_urls+=("${ssh_template//\{repo\}/$repo_name}")
    done < "$MIRRORS_CFG"

    [[ ${#mirror_platforms[@]} -gt 0 ]] || die "no mirrors defined in $MIRRORS_CFG"
}

repo_exists() {
    local platform="$1" username="$2"
    local url status token

    case "$platform" in
        github)
            token="$GITHUB_TOKEN"
            url="$GITHUB_API_BASE/repos/$username/$repo_name"
            ;;
        forgejo)
            token="$FORGEJO_TOKEN"
            url="$FORGEJO_API_BASE/repos/$username/$repo_name"
            ;;
    esac

    status=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: Bearer $token" \
        "$url")

    [[ "$status" == "200" ]]
}

create_repo() {
    local platform="$1" username="$2" description="$3"
    local url token payload response http_status_code body

    local private_str_var="false"
    $private && private_str_var="true"

    case "$platform" in
        github)
            token="$GITHUB_TOKEN"
            if $org_mode; then
                url="$GITHUB_API_BASE/orgs/$username/repos"
            else
                url="$GITHUB_API_BASE/user/repos"
            fi
            payload=$(jq -n \
                --arg name "$repo_name" \
                --arg desc "$description" \
                --argjson private "$private_str_var" \
                '{name: $name, description: $desc, private: $private, auto_init: false}')
            ;;
        forgejo)
            token="$FORGEJO_TOKEN"
            if $org_mode; then
                url="$FORGEJO_API_BASE/orgs/$username/repos"
            else
                url="$FORGEJO_API_BASE/user/repos"
            fi
            payload=$(jq -n \
                --arg name "$repo_name" \
                --arg desc "$description" \
                --argjson private "$private_str_var" \
                '{name: $name, description: $desc, private: $private, auto_init: false}')
            ;;
    esac

    if repo_exists "$platform" "$username"; then
        echo "[+] repository $repo_name already exists on $platform, skipping creation"
        return
    fi

    printf "[~] creating new repository $repo_name on $platform... "

    response=$(curl -s -w "\n%{http_code}" \
        -X POST \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        -H "Accept: application/json" \
        -d "$payload" \
        "$url")

    http_status_code="${response##*$'\n'}"
    body="${response%$'\n'*}"

    case "$http_status_code" in
        201)
            printf "success!\n"
            ;;
        *)
            printf "failed\n"
            echo "[!] response body: $body" >&2
            die "api comms failed with unexpected http status $http_status_code"
            ;;
    esac
}

repo_init() {
    parse_mirrors
    prompt_description

    if ! git remote get-url origin &>/dev/null; then
        git remote add origin "${mirror_urls[0]}"
        echo "[+] created origin remote: ${mirror_urls[0]}"
    fi

    # clear existing push urls so we rebuild from scratch
    git config --unset-all remote.origin.pushurl 2>/dev/null || true

    for i in "${!mirror_platforms[@]}"; do
        local desc="$repo_description"
        (( i > 0 )) && desc="[MIRROR] $desc"
        create_repo "${mirror_platforms[$i]}" "${mirror_users[$i]}" "$desc" # skips if one already exists (bravely assuming no naming conflicts)
        git remote set-url --add --push origin "${mirror_urls[$i]}"
        echo "[+] new remote push url: ${mirror_urls[$i]}"
    done
}

restore_handler() {
    local target_name="$1"
    repo_name="$target_name"
    parse_mirrors

    # verify repos exist on all mirrors before configuring remotes
    for i in "${!mirror_platforms[@]}"; do
        local platform="${mirror_platforms[$i]}"
        local username="${mirror_users[$i]}"

        printf "[~] checking if $repo_name exists on $platform... "
        if repo_exists "$platform" "$username"; then
            printf "found\n"
        else
            printf "not found\n"
            die "repository $repo_name does not exist on $platform, cannot restore"
        fi
    done

    # configure git remotes (same logic as repo_init but without creating repos)
    if ! git remote get-url origin &>/dev/null; then
        git remote add origin "${mirror_urls[0]}"
        echo "[+] created origin remote: ${mirror_urls[0]}"
    else
        git remote set-url origin "${mirror_urls[0]}"
        echo "[+] updated origin remote: ${mirror_urls[0]}"
    fi

    # clear existing push urls so we rebuild from scratch
    git config --unset-all remote.origin.pushurl 2>/dev/null || true

    for i in "${!mirror_platforms[@]}"; do
        git remote set-url --add --push origin "${mirror_urls[$i]}"
        echo "[+] added remote push url: ${mirror_urls[$i]}"
    done
}

rename_repo() {
    local platform="$1" username="$2" new_name="$3"
    local url token payload response http_status_code body

    case "$platform" in
        github)
            token="$GITHUB_TOKEN"
            url="$GITHUB_API_BASE/repos/$username/$repo_name"
            ;;
        forgejo)
            token="$FORGEJO_TOKEN"
            url="$FORGEJO_API_BASE/repos/$username/$repo_name"
            ;;
    esac

    payload=$(jq -n --arg name "$new_name" '{name: $name}')

    printf "[~] renaming $repo_name -> $new_name on $platform... "

    response=$(curl -s -w "\n%{http_code}" \
        -X PATCH \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        -H "Accept: application/json" \
        -d "$payload" \
        "$url")

    http_status_code="${response##*$'\n'}"
    body="${response%$'\n'*}"

    case "$http_status_code" in
        200)
            printf "success!\n"
            ;;
        *)
            printf "failed\n"
            echo "[!] response body: $body" >&2
            die "api comms failed with unexpected http status $http_status_code"
            ;;
    esac
}

rename_handler() {
    local new_name="$1"
    parse_mirrors
    
    for i in "${!mirror_platforms[@]}"; do
        rename_repo "${mirror_platforms[$i]}" "${mirror_users[$i]}" "$new_name"
    done
    
    git config --unset-all remote.origin.pushurl 2>/dev/null || true
    
    local new_origin_url="${mirror_templates[0]//\{repo\}/$new_name}"
    git remote set-url origin "$new_origin_url"
    echo "[+] updated origin: $new_origin_url"
    
    for i in "${!mirror_templates[@]}"; do
        local new_url="${mirror_templates[$i]//\{repo\}/$new_name}"
        git remote set-url --add --push origin "$new_url"
        echo "[+] updated push url: $new_url"
    done
}

describe_repo() {
    local platform="$1" username="$2" description="$3"
    local url token payload response http_status_code body

    case "$platform" in
        github)
            token="$GITHUB_TOKEN"
            url="$GITHUB_API_BASE/repos/$username/$repo_name"
            ;;
        forgejo)
            token="$FORGEJO_TOKEN"
            url="$FORGEJO_API_BASE/repos/$username/$repo_name"
            ;;
    esac

    payload=$(jq -n --arg desc "$description" '{description: $desc}')

    printf "[~] updating description on $platform... "

    response=$(curl -s -w "\n%{http_code}" \
        -X PATCH \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        -H "Accept: application/json" \
        -d "$payload" \
        "$url")

    http_status_code="${response##*$'\n'}"
    body="${response%$'\n'*}"

    case "$http_status_code" in
        200)
            printf "success!\n"
            ;;
        *)
            printf "failed\n"
            echo "[!] response body: $body" >&2
            die "api comms failed with unexpected http status $http_status_code"
            ;;
    esac
}

desc_handler() {
    local description="$1"
    parse_mirrors

    for i in "${!mirror_platforms[@]}"; do
        local desc="$description"
        (( i > 0 )) && desc="[MIRROR] $desc"
        describe_repo "${mirror_platforms[$i]}" "${mirror_users[$i]}" "$desc"
    done
}

usage() {
    echo "[?] usage: ferne [cmd]"
    echo "      init             create new mirrored (public) repository (prompts for description)"
    echo "      private          create new mirrored (private) repository (prompts for description)"
    echo "      rename <name>    rename the (existing) mirrors"
    echo "      desc <content>   set description to mirrors"
    echo "      restore <name>   restore mirror remotes for existing repository"
    echo "      help             print this menu"
    echo ""
    echo "      prefix any command with \"corpo <org_name>\" to use that org's mirror/token configs"
    echo "      e.g.: \"ferne corpo acme init\" (the available orgs can be listed with \"ferne corpo ls\")"
}

mirror_platforms=()
mirror_users=()
mirror_templates=()
mirror_urls=()

private=false
org_mode=false

# switch to org configs when invoked as: ferne corpo <org_name> <cmd> [arg]
if [[ "${1:-}" == "corpo" ]]; then
    if [[ "${2:-}" == "ls" ]]; then
        [[ -d "$ORGS_DIR" ]] || { echo "(no orgs configured at $ORGS_DIR)"; exit 0; }
        for d in "$ORGS_DIR"/*/; do
            [[ -d "$d" ]] && basename "$d" || true
        done
        exit 0
    fi

    [[ $# -lt 3 ]] && die "corpo requires an org name and a command"

    org_name="$2"
    MIRRORS_CFG="$ORGS_DIR/$org_name/mirrors"
    TOKENS_ENV="$ORGS_DIR/$org_name/tokens.gpg"
    org_mode=true
    shift 2
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not inside a git repository"
repo_name="$(basename "$repo_root")"

[[ $# -eq 0 || $# -gt 2 ]] && die "invalid arguments, see help for more details"

require_cmd gpg
require_cmd git
require_cmd jq
require_cmd curl

case "$1" in
    init) export_tokens && repo_init ;;
    private) private=true; export_tokens && repo_init ;;
    rename) [[ $# -ne 2 ]] && die "'rename' requires a new name argument"; export_tokens && rename_handler "$2" ;;
    desc) [[ $# -ne 2 ]] && die "'desc' requires a content argument"; export_tokens && desc_handler "$2" ;;
    restore) [[ $# -ne 2 ]] && die "'restore' requires a repository name argument"; export_tokens && restore_handler "$2" ;;
    help|-h) usage; exit 0 ;;
    *) die "unknown option '$1'" ;;
esac

